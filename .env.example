# ── Required ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_use_a_strong_password

# ── AI providers (at least one recommended) ────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Ports (optional, defaults shown) ──────────────────────────────
TSM_PORT=8080
DASHBOARD_PORT=3001

# ── Alerting (optional) ────────────────────────────────────────────
TSM_WEBHOOK_URL=          # Slack/Teams/custom webhook for CRITICAL events

# ── Advanced ──────────────────────────────────────────────────────
TSM_RATE_LIMIT=100        # requests per minute per client IP
PROXY_EXTERNAL_URL=http://localhost:8080   # URL clients use to reach proxy
