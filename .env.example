# ── Required ────────────────────────────────────────────────────────────────────
# Strong password for the PostgreSQL database (used by detector for audit log).
# Use: openssl rand -base64 24
POSTGRES_PASSWORD=changeme_use_a_strong_password

# ── AI Providers (at least one needed for real upstream forwarding) ───────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Ports (optional, defaults shown) ────────────────────────────────────────────
# Port the proxy listens on. Point your OpenAI client here:
#   OPENAI_BASE_URL=http://localhost:8080/v1
TSM_PORT=8080

# ── Alerting (optional) ──────────────────────────────────────────────────────────
# Webhook URL for CRITICAL events (risk_score ≥ 80 or block).
# Auto-detects format: Slack (hooks.slack.com), Teams (webhook.office.com), or generic.
# Example Slack: https://hooks.slack.com/services/T.../B.../...
TSM_WEBHOOK_URL=

# ── Advanced (optional) ──────────────────────────────────────────────────────────
# Requests per minute per client IP before rate-limiting kicks in.
TSM_RATE_LIMIT=100

# The public URL clients use to reach the proxy (used by dashboard's CORS + self-links).
# Override if the proxy is behind a reverse proxy or load balancer.
PROXY_EXTERNAL_URL=http://localhost:8080

# Go proxy audit log secret — HMAC key for tamper-proof chain.
# Use: openssl rand -hex 32
# If unset, defaults to "change-me-in-production" (logged as WARNING on startup).
TSM_AUDIT_SECRET=

# Detector failure mode when the Python service is unreachable:
#   allow   — pass traffic through (fail open, default — safe for dev)
#   block   — return 503 until detector recovers (strict, recommended for prod)
#   degrade — apply local regex only, skip ML scan
TSM_DETECTOR_FAILURE_MODE=allow
