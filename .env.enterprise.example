##############################################################################
# TSM Enterprise — Environment Template
# Copy this file to .env and fill in ALL values marked REQUIRED.
#
#   cp .env.enterprise.example .env
#   # edit .env
#   docker compose -f docker-compose.enterprise.yml up -d
#
# SECURITY: .env must never be committed to version control.
# Add it to .gitignore:  echo ".env" >> .gitignore
##############################################################################


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Password for the `tsm` database user.
# REQUIRED — minimum 32 random characters recommended.
# Generate: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32


# ── Redis ─────────────────────────────────────────────────────────────────────
# Password for the Redis server.
# REQUIRED — minimum 24 random characters.
# Generate: openssl rand -hex 20
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_20


# ── Dataplane ─────────────────────────────────────────────────────────────────

# HMAC-SHA256 signing key for the tamper-evident audit chain.
# REQUIRED — must be exactly 64 hex characters (256-bit key).
# Generate: openssl rand -hex 32
TSM_AUDIT_SECRET=CHANGE_ME_64_hex_chars

# Maximum upstream AI API requests per minute (per source IP, token-bucket).
# Default: 500 (generous for enterprise; reduce for single-tenant deployments)
TSM_RATE_LIMIT=500

# Detector failure mode: allow | block
# allow  = let traffic through if the ML detector is unavailable
# block  = reject requests if the ML detector is unavailable (strict mode)
TSM_DETECTOR_FAILURE_MODE=allow

# Detector timeout in milliseconds.
TSM_DETECTOR_TIMEOUT_MS=5000

# Log level for the Rust dataplane: trace | debug | info | warn | error
TSM_LOG_LEVEL=info

# Optional: Kafka broker list for streaming audit events.
# Leave empty to disable Kafka. Format: host1:9092,host2:9092
TSM_KAFKA_BROKERS=

# Optional: Ed25519 public key (base64-encoded) from control plane policy signer.
# Leave empty during initial setup; populate after generating key pair.
# Generate (in control-plane): tsm-ctl policy keygen
TSM_POLICY_PUBKEY_B64=


# ── Workspace / Org IDs ───────────────────────────────────────────────────────
# UUIDs that scope audit events and policy to your organization.
# Defaults are valid for single-org deployments. Override for multi-tenant.
TSM_ORG_ID=00000000-0000-0000-0000-000000000001
TSM_WORKSPACE_ID=00000000-0000-0000-0000-000000000002


# ── Admin API (Java Spring Boot) ──────────────────────────────────────────────
# JWT signing secret — minimum 32 characters, no spaces.
# REQUIRED — rotate this before going to production.
# Generate: openssl rand -base64 36
TSM_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_36


# ── Control Plane ─────────────────────────────────────────────────────────────
# Priority queue limits for the control plane scheduler.
# 0 = unlimited.
TSM_QUEUE_GOLD_LIMIT=0
TSM_QUEUE_SILVER_LIMIT=500
TSM_QUEUE_BRONZE_LIMIT=50


# ── Upstream AI APIs ──────────────────────────────────────────────────────────
# At least one key is required for the AI proxy to forward requests.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...


# ── Nginx / Public URLs ───────────────────────────────────────────────────────
# Ports nginx binds on the host.
HTTP_PORT=80
HTTPS_PORT=443

# External URL the dashboard uses to reach the AI proxy.
# Set to your domain (e.g. https://tsm.example.com) in production.
TSM_EXTERNAL_URL=http://localhost:8080

# External URL the dashboard uses to reach the admin API.
TSM_ADMIN_URL=http://localhost:9090


# ── ClickHouse Analytics ──────────────────────────────────────────────────────
# Password for the ClickHouse `tsm` user.
# REQUIRED if analytics is enabled.
# Generate: openssl rand -hex 20
CLICKHOUSE_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_20

# ClickHouse connection URL for the Rust dataplane (ingestor).
# Format: http://user:password@host:8123
# Leave empty to disable analytics ingestion.
TSM_CLICKHOUSE_URL=http://tsm:${CLICKHOUSE_PASSWORD}@localhost:8123


# ── Threat Intelligence APIs ──────────────────────────────────────────────────
# NVD (National Vulnerability Database) API key — optional, raises rate limit.
# Get at: https://nvd.nist.gov/developers/request-an-api-key
TSM_NVD_API_KEY=

# AbuseIPDB API key — REQUIRED for AbuseIPDB feed (IP reputation).
# Get at: https://www.abuseipdb.com/account/api
TSM_ABUSEIPDB_KEY=

# AlienVault OTX API key — REQUIRED for OTX feed (IOC + IP reputation).
# Get at: https://otx.alienvault.com/api
TSM_OTX_API_KEY=

# Redis URL for the threat-intel service (can share with dataplane Redis).
# Format: redis://:password@host:6379
TSM_REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# Threat-intel service HTTP listen address (for /health, /metrics, /intel/*).
TSM_INTEL_LISTEN=:9100


# ── BGP Anycast Routing (ExaBGP) ─────────────────────────────────────────────
# Used for sovereign routing: announce AI provider CIDRs via your own AS
# so traffic bypasses third-party edge (Cloudflare, etc.).
# Only required for bare-metal / DC deployments with BGP upstreams.

# Your BGP Router ID (must be a valid IPv4 address, typically the node's loopback)
TSM_ROUTER_ID=10.0.0.1

# Your Autonomous System Number
TSM_BGP_LOCAL_AS=65000

# Upstream BGP peer 1
TSM_BGP_PEER_1_IP=10.0.0.254
TSM_BGP_PEER_1_AS=65001

# Next-hop IP for announced routes
TSM_BGP_NEXT_HOP=10.0.0.1

# WireGuard mesh — local node IP on wg0 (10.99.0.x)
TSM_MESH_IP=10.99.0.1
TSM_MESH_LISTEN_PORT=51820


# ── Optional: HashiCorp Vault (secrets-bootstrap.sh) ─────────────────────────
# Only needed if you use deploy/scripts/secrets-bootstrap.sh
# VAULT_ADDR=https://vault.example.com
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=
