#!/bin/sh
# Maven Wrapper script — downloads Maven if not cached, then runs it.
# Generated by Spring Initializr / maven-wrapper-plugin 3.2.0
set -e

# Find the Maven wrapper jar
MAVEN_WRAPPER_JAR="$( cd "$( dirname "$0" )" && pwd )/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$( cd "$( dirname "$0" )" && pwd )/.mvn/wrapper/maven-wrapper.properties"

# Resolve distributionUrl from properties
DISTRIBUTION_URL=$(grep "^distributionUrl=" "$MAVEN_WRAPPER_PROPERTIES" | cut -d= -f2-)

# Cache directory
MVN_HOME="$HOME/.m2/wrapper/dists"
MVN_DIST="${MVN_HOME}/$(basename "$DISTRIBUTION_URL" .zip)"

if [ ! -d "$MVN_DIST" ]; then
  mkdir -p "$MVN_DIST"
  echo "Downloading Maven from $DISTRIBUTION_URL ..."
  curl -fsSL "$DISTRIBUTION_URL" -o "$MVN_DIST/apache-maven.zip"
  unzip -q "$MVN_DIST/apache-maven.zip" -d "$MVN_DIST"
fi

MVN_BIN=$(find "$MVN_DIST" -name "mvn" -type f | head -1)
exec "$MVN_BIN" "$@"
